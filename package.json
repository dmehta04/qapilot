{
  "name": "qapilot",
  "version": "0.1.0",
  "description": "AI-powered multi-layer QA pipeline for any stack",
  "type": "module",
  "bin": {
    "qapilot": "./bin/qapilot.cjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outdir=dist --packages=external && esbuild bin/qapilot.ts --bundle --platform=node --format=cjs --outfile=bin/qapilot.cjs --packages=external --banner:js='#!/usr/bin/env node'",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"bin/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "chalk": "^5.4.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "MIT"
}
